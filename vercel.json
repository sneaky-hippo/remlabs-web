{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://slopshop-production.up.railway.app https://slopshop.gg; frame-src 'none'; object-src 'none'; base-uri 'self'" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }]
    }
  ],
  "redirects": [
    { "source": "/dashboard", "destination": "/memory", "permanent": false },
    { "source": "/brain", "destination": "/memory", "permanent": false },
    { "source": "/signup", "destination": "/", "permanent": false },
    { "source": "/login", "destination": "/", "permanent": false },
    { "source": "/dev-console", "destination": "https://slopshop.gg/dev-console", "permanent": false },
    { "source": "/api", "destination": "https://slopshop.gg", "permanent": false },
    { "source": "/developers", "destination": "https://slopshop.gg", "permanent": false },
    { "source": "/docs", "destination": "https://slopshop.gg", "permanent": false },
    { "source": "/for/agents", "destination": "/for/research-agents", "permanent": false },
    { "source": "/playground", "destination": "https://slopshop.gg", "permanent": false }
  ],
  "rewrites": [
    { "source": "/morning", "destination": "/morning" },
    { "source": "/now", "destination": "/morning" },
    { "source": "/context", "destination": "/context" },
    { "source": "/memory", "destination": "/memory-hub" },
    { "source": "/dream", "destination": "/dream-studio" },
    { "source": "/morning-brief", "destination": "/dream-reports" },
    { "source": "/hive", "destination": "/dream-studio" },
    { "source": "/coma", "destination": "/dream-studio" },
    { "source": "/explorer", "destination": "/memory-explorer" },
    { "source": "/skills", "destination": "/skills-forge" },
    { "source": "/vs/supermemory", "destination": "/vs-supermemory" },
    { "source": "/vs/:slug", "destination": "/vs-:slug" },
    { "source": "/privacy", "destination": "/privacy" },
    { "source": "/terms", "destination": "/terms" },
    { "source": "/for/research-agents", "destination": "/for-research-agents" },
    { "source": "/for/crypto-agents", "destination": "/for-crypto-agents" },
    { "source": "/for/coding-agents", "destination": "/for-coding-agents" },
    { "source": "/for/customer-support", "destination": "/for-customer-support" },
    { "source": "/press", "destination": "/press" },
    { "source": "/security", "destination": "/security" },
    { "source": "/community", "destination": "/community" },
    { "source": "/blog", "destination": "/blog" },
    { "source": "/cli-login", "destination": "/cli-login" },
    { "source": "/console", "destination": "/console" },
    { "source": "/automations", "destination": "/automations" },
    { "source": "/wrapped", "destination": "/wrapped" },
    { "source": "/integrations-console", "destination": "/console" },
    { "source": "/v1/:path*", "destination": "https://slopshop-production.up.railway.app/v1/:path*" },
    { "source": "/auth/:path*", "destination": "https://slopshop-production.up.railway.app/auth/:path*" },
    { "source": "/zapier/:path*", "destination": "https://slopshop-production.up.railway.app/zapier/:path*" },
    { "source": "/.well-known/:path*", "destination": "https://slopshop-production.up.railway.app/.well-known/:path*" }
  ]
}
